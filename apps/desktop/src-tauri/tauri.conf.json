{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Lan Code",
  "version": "0.2.10",
  "identifier": "dev.lancode.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Lan Code",
        "width": 1440,
        "height": 940,
        "minWidth": 1040,
        "minHeight": 700,
        "resizable": true,
        "center": true,
        "decorations": false,
        "shadow": true,
        "windowClassname": "LanCodeDesktopV027OfficeMode"
      }
    ],
    "security": { "csp": null }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "publisher": "Lan Code",
    "copyright": "Copyright © 2026 Lan Code",
    "shortDescription": "Lan Code AI 编程工作台",
    "longDescription": "集 Agent、代码编辑、项目理解、终端与 Git 审查于一体的 AI 编程工作台。",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "languages": ["SimpChinese"],
        "displayLanguageSelector": false,
        "installMode": "currentUser"
      },
      "wix": {
        "language": "zh-CN"
      }
    }
  }
}
