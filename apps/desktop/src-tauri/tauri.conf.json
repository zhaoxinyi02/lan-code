{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Lan Code",
  "version": "0.2.0",
  "identifier": "dev.lancode.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Lan Code",
        "width": 1440,
        "height": 940,
        "minWidth": 1040,
        "minHeight": 700,
        "resizable": true,
        "center": true
      }
    ],
    "security": { "csp": null }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ]
  }
}
